{
  "name": "@alt-javascript/jsmdma-core",
  "version": "1.0.0",
  "description": "Isomorphic core for jsmdma: HLC revision clock, field-level diff, and merge engine",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "build": "esbuild index.js --bundle --format=esm --outfile=dist/jsmdma-core.esm.js",
    "test": "mocha --recursive test/**/*.spec.js"
  },
  "keywords": [
    "jsmdma",
    "alt-javascript",
    "sync",
    "hlc",
    "crdt",
    "offline-first",
    "isomorphic"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://github.com/alt-javascript/jsmdma/tree/main/packages/jsmdma-core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/alt-javascript/jsmdma",
    "directory": "packages/core"
  },
  "devDependencies": {
    "chai": "^4.3.7",
    "esbuild": "^0.25.0",
    "mocha": "^11.7.5"
  },
  "license": "MIT",
  "author": "Craig Parravicini",
  "contributors": [
    "Claude (Anthropic)"
  ],
  "engines": {
    "node": ">=20"
  }
}
