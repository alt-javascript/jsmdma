{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user",
  "title": "User",
  "description": "A user record stored in the 'users' collection, keyed by userId.",
  "type": "object",
  "required": ["userId", "providers"],
  "properties": {
    "userId": {
      "type": "string",
      "description": "UUID identifying the user"
    },
    "email": {
      "type": ["string", "null"],
      "description": "User's email address; null when not known"
    },
    "providers": {
      "type": "array",
      "description": "OAuth / identity provider links",
      "items": {
        "type": "object",
        "required": ["provider", "providerUserId"],
        "properties": {
          "provider": {
            "type": "string",
            "description": "Provider name, e.g. 'github', 'google'"
          },
          "providerUserId": {
            "type": "string",
            "description": "User identifier within the provider"
          }
        },
        "additionalProperties": false
      }
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 creation timestamp"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 last-updated timestamp"
    }
  },
  "additionalProperties": false
}
