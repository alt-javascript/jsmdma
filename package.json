{
  "name": "jsmdma",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/jsmdma-core",
    "test": "npm test --workspaces --if-present",
    "test:core": "npm test -w packages/jsmdma-core",
    "test:server": "npm test -w packages/jsmdma-server",
    "test:hono": "npm test -w packages/jsmdma-hono",
    "test:example": "npm test -w packages/example"
  },
  "engines": {
    "node": ">=20"
  }
}
